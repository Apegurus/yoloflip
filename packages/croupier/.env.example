# Private key for the croupier wallet (has CROUPIER_ROLE on YoloFlip contract)
CROUPIER_PRIVATE_KEY=0x...

# Private key for the secret signer (signs commits for players)
SECRET_SIGNER_KEY=0x...

# RPC URL for the target chain
RPC_URL=http://localhost:8545

# Deployed YoloFlip contract address
CONTRACT_ADDRESS=0x...

# Port for the commit signing API
PORT=3001

# How many blocks from current to set commitLastBlock
COMMIT_BLOCK_OFFSET=100

# Allowed CORS origin for the commit signing API
ALLOWED_ORIGIN=http://localhost:3000
